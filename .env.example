# ============================================================
# Capital Placement Engine — Environment Variables
# ============================================================
# Copy this to .env.local and fill in your values
# The app works WITHOUT any env vars (mock data mode)

# --- Supabase (required for real data persistence) ---
# 1. Create project at https://supabase.com/dashboard
# 2. Run supabase/schema.sql in SQL Editor
# 3. Run supabase/rls-policies.sql in SQL Editor
# 4. Run supabase/seed.sql (optional — demo data)
# 5. Copy URL + anon key from Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend (Email)
RESEND_API_KEY=your-resend-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Firm compliance
FIRM_NAME=Your Firm Name
FIRM_DISCLOSURE_TEXT=Securities offered through [Firm Name], Member FINRA/SIPC.
